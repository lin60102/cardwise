{
  "expo": {
    "name": "CardWise",
    "slug": "cardwise",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "cardwise",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "assets/images/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cardwise.app"
    },
    "android": {
      "package": "com.cardwise.app"
    },
    "plugins": [],
    "extra": {
      "apiUrl": "http://localhost:4000"
    }
  }
}
